// Prisma schema for MétodoAI — multi-tenant SaaS CRM.
//
// Tenancy model: every tenant is an `Organization`. A `User` is a global
// identity that joins one or more organizations via `Membership` (carrying the
// role). Every business record (CRM, prospecting, campaigns…) added in later
// phases MUST carry `organizationId` and be filtered by it in the DAL
// (src/lib/queries) — that is the security boundary. See PLANO.md §5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime connection. On Neon/Supabase use the POOLED (pgBouncer) URL.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for `prisma migrate`/`db push` — migrations
  // can't run through a transaction pooler. Locally it's the same URL.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Tenancy & Auth
// ---------------------------------------------------------------------------

/// Role of a user *within* an organization.
enum Role {
  OWNER
  ADMIN
  MEMBER
}

/// Subscription tier. Gates features + seats + dispatch quota (src/config/plans.ts).
enum Plan {
  STANDARD
  PLUS
  GOLD
  ENTERPRISE
}

/// A tenant. All business data hangs off an organization via `organizationId`.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(STANDARD)
  seatLimit Int      @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      Membership[]
  invitations      Invitation[]
  notifications        Notification[]
  teamChats            TeamChat[]
  teamChatParticipants TeamChatParticipant[]
  teamChatMessages     TeamChatMessage[]
  teamChatFolders      TeamChatFolder[]
  feedPosts            FeedPost[]
  feedPostAttachments  FeedPostAttachment[]
  feedMentions         FeedMention[]
  feedReactions        FeedReaction[]
  pinnedItems          PinnedItem[]

  @@map("organizations")
}

/// A global user identity (login). Belongs to orgs through memberships.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships          Membership[]
  profile              UserProfile?
  notifications        Notification[]
  teamChatParticipants TeamChatParticipant[]
  teamChatMessages     TeamChatMessage[]
  feedPosts            FeedPost[]
  feedMentions         FeedMention[]
  feedReactions        FeedReaction[]

  @@map("users")
}

/// Document kind for a user profile. Brazilian individuals use CPF; companies
/// (or self-employed) use CNPJ.
enum DocumentType {
  CPF
  CNPJ
}

/// Rich profile for a user account, created from the data filled when the
/// account is created (signup or invite acceptance). Identity-level (tied to
/// the User, not an org) — an admin reads a member's profile through their
/// Membership (org-scoped). 1:1 with User.
model UserProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  phone         String?
  documentType  DocumentType?
  document      String? // digits only (normalized); validated as CPF/CNPJ
  position      String? // cargo/função na organização
  birthDate     DateTime?
  avatarUrl     String?
  addressZip    String?
  addressStreet String?
  addressNumber String?
  addressCity   String?
  addressState  String? // UF
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// Join between a user and an organization, carrying the role.
model Membership {
  id               String   @id @default(cuid())
  organizationId   String
  userId           String
  role             Role     @default(MEMBER)
  /// Access template restricting which screens a MEMBER can reach. Null = full
  /// access. OWNER/ADMIN ignore this (they always have full access).
  accessTemplateId String?
  /// Team-chat organization (org-shared, like the WhatsApp inbox folders):
  /// which folder this member sits in, and whether they're pinned to the top.
  teamFolderId     String?
  teamPinned       Boolean  @default(false)
  createdAt        DateTime @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessTemplate AccessTemplate? @relation(fields: [accessTemplateId], references: [id], onDelete: SetNull)
  teamFolder     TeamChatFolder? @relation(fields: [teamFolderId], references: [id], onDelete: SetNull)

  // One team per user: a user has at most one membership.
  @@unique([organizationId, userId])
  @@unique([userId])
  @@index([accessTemplateId])
  @@index([teamFolderId])
  @@map("memberships")
}

/// A named, reusable access profile (e.g. "Comercial", "Jurídico") that grants
/// MEMBERs access to a specific set of screens. Org-scoped.
model AccessTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  /// Allowed screen keys (see src/config/screens.ts).
  screens        String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships Membership[]

  @@index([organizationId])
  @@map("access_templates")
}

/// A pending invitation to join an organization with a given role.
model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           Role      @default(MEMBER)
  tokenHash      String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

// ---------------------------------------------------------------------------
// CRM (P3) — all rows carry `organizationId` (the tenant boundary). Reads go
// through the tenant-scoped client (src/lib/tenant-db.ts) / DAL; writes-by-id
// use `where: { id, organizationId }`.
// ---------------------------------------------------------------------------

/// A company in the CRM (a prospect or client account).
model Company {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  cnpj           String?
  email          String?
  phone          String?
  website        String?
  /// Address broken down: { street, number, district, city, uf, zip, country }.
  address        Json     @default("{}")
  notes          String?
  /// Where it came from: "manual", "extractor:google", "import"…
  source         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contacts      Contact[]
  opportunities Opportunity[]

  @@index([organizationId, name])
  @@index([organizationId, cnpj])
  @@map("companies")
}

/// A person in the CRM, optionally tied to a company.
model Contact {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String?
  folderId       String?
  name           String
  email          String?
  phone          String?
  role           String?
  tags           String[] @default([])
  source         String?
  /// LGPD: when true, the contact is excluded from campaigns (unsubscribed).
  optedOut       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company            Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  folder             ContactFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  opportunities      Opportunity[]
  campaignRecipients CampaignRecipient[]

  @@index([organizationId, companyId])
  @@index([organizationId, folderId])
  @@index([organizationId, name])
  @@map("contacts")
}

/// A user-defined folder to organize contacts (drag-and-drop on the grid view).
model ContactFolder {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contacts Contact[]

  @@index([organizationId, order])
  @@map("contact_folders")
}

/// A sales pipeline (a board). Each org gets a default one.
model Pipeline {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stages        Stage[]
  opportunities Opportunity[]

  @@index([organizationId])
  @@map("pipelines")
}

/// A column of a pipeline (a funnel stage).
model Stage {
  id             String   @id @default(cuid())
  organizationId String
  pipelineId     String
  name           String
  order          Int      @default(0)
  probability    Int      @default(0) // 0–100
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]

  @@index([organizationId, pipelineId, order])
  @@map("stages")
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  CANCELED
}

/// Whether a catalog item is a physical product or a service.
enum ProductKind {
  PRODUCT
  SERVICE
}

/// Catalog of products/services an opportunity can be tied to (org-scoped).
model ProductService {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  kind           ProductKind @default(SERVICE)
  price          Decimal?    @db.Decimal(14, 2)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  opportunities Opportunity[]

  @@index([organizationId, active])
  @@map("product_services")
}

/// A deal / card on the Kanban board.
model Opportunity {
  id                String            @id @default(cuid())
  organizationId    String
  pipelineId        String
  stageId           String
  companyId         String?
  contactId         String?
  productServiceId  String?
  title             String
  /// Sequential per-org-per-year code, e.g. "0001/26".
  code              String?
  seqYear           Int?
  seqNumber         Int?
  value             Decimal           @default(0) @db.Decimal(14, 2)
  status            OpportunityStatus @default(OPEN)
  order             Int               @default(0) // position within the stage column
  ownerId           String? // membership/user responsible
  createdById       String? // membership/user who created it (for notifications)
  expectedCloseDate DateTime? // data prevista de fechamento
  notes             String?
  /// Reason for losing/canceling (required when status is LOST/CANCELED).
  outcomeReason     String?
  closedAt          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  pipeline       Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage          Stage           @relation(fields: [stageId], references: [id], onDelete: Restrict)
  company        Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  productService ProductService? @relation(fields: [productServiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, pipelineId, stageId, order])
  @@index([organizationId, seqYear, seqNumber])
  @@map("opportunities")
}

// ---------------------------------------------------------------------------
// Connections & Webhooks (P4)
// ---------------------------------------------------------------------------

enum IntegrationProvider {
  EVOLUTION // WhatsApp via Evolution API
  META_CLOUD // WhatsApp Cloud API (Meta)
  GOOGLE // Maps / Custom Search
  RESEND // transactional / campaign email
  SMTP // generic SMTP
  N8N // workflow automation
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
}

/// A stored, per-tenant integration credential set. `credentialsEnc` is an
/// AES-256-GCM payload (see src/lib/integrations/crypto.ts) — never plaintext.
model IntegrationConnection {
  id             String              @id @default(cuid())
  organizationId String
  provider       IntegrationProvider
  label          String
  credentialsEnc String
  status         ConnectionStatus    @default(INACTIVE)
  lastTestAt     DateTime?
  meta           Json                @default("{}")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId, provider])
  @@map("integration_connections")
}

/// Inbound webhook endpoint configuration (a provider calls us here).
model WebhookEndpoint {
  id             String              @id @default(cuid())
  organizationId String
  provider       IntegrationProvider
  secret         String
  events         String[]            @default([])
  createdAt      DateTime            @default(now())

  @@index([organizationId, provider])
  @@map("webhook_endpoints")
}

/// Idempotent log of received webhook events (dedupe by `dedupeKey`).
model WebhookEvent {
  id             String              @id @default(cuid())
  organizationId String?
  provider       IntegrationProvider
  eventType      String
  dedupeKey      String              @unique
  payload        Json
  processedAt    DateTime?
  createdAt      DateTime            @default(now())

  @@index([organizationId, provider, eventType])
  @@map("webhook_events")
}

// ---------------------------------------------------------------------------
// Dispatch / Campaigns (P6)
// ---------------------------------------------------------------------------

enum Channel {
  WHATSAPP_EVOLUTION
  WHATSAPP_CLOUD
  EMAIL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  DONE
  CANCELED
}

enum RecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

/// A reusable message template. `body` may contain {{nome}} / {{empresa}}.
model MessageTemplate {
  id             String   @id @default(cuid())
  organizationId String
  channel        Channel
  name           String
  subject        String? // for EMAIL
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, channel])
  @@map("message_templates")
}

/// A dispatch campaign over a channel.
model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  channel        Channel
  templateId     String?
  status         CampaignStatus @default(DRAFT)
  startAt        DateTime?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  recipients CampaignRecipient[]

  @@index([organizationId, status])
  @@map("campaigns")
}

/// One contact's slot in a campaign. Unique per (campaign, contact) so retries
/// never double-send.
model CampaignRecipient {
  id                String          @id @default(cuid())
  organizationId    String
  campaignId        String
  contactId         String
  status            RecipientStatus @default(PENDING)
  providerMessageId String?
  error             String?
  sentAt            DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // Deleting a contact removes its slots from every campaign (no orphan rows).
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([organizationId, status])
  @@index([campaignId, status])
  @@index([providerMessageId])
  @@map("campaign_recipients")
}

// ---------------------------------------------------------------------------
// Audit log (P8)
// ---------------------------------------------------------------------------

/// Immutable trail of meaningful actions, per organization.
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String // e.g. "campaign.started"
  entity         String // e.g. "Campaign"
  entityId       String?
  meta           Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Prospecting / lead extraction
// ---------------------------------------------------------------------------
// Discovery uses the official Google Places API (the tenant's own key); each
// result's website is then scraped for public contact info. Google Places data
// is treated as EPHEMERAL per Google's ToS (no long-term storage) — a scheduled
// job prunes finished extractions after a retention window. The durable record
// is what the user explicitly imports into the CRM.

enum ExtractionStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  CANCELED
}

/// A prospecting run: a Google Places text query enriched by website scraping.
model ExtractionJob {
  id             String           @id @default(cuid())
  organizationId String
  /// Search params: { segmento, localidade, nome, cnpj }.
  query          Json             @default("{}")
  status         ExtractionStatus @default(QUEUED)
  /// How many leads to collect (null = provider default, capped server-side).
  target         Int?
  /// Leads found so far.
  total          Int              @default(0)
  /// Google Places pagination cursor for the next batch.
  pageToken      String?
  error          String?
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  leads ExtractedLead[]

  @@index([organizationId, status])
  @@index([status, createdAt])
  @@map("extraction_jobs")
}

/// One discovered business. Discovery fields (name/address/phone/website) come
/// from Google Places; enrichment fields (email/socials) come from the
/// business's own public website.
model ExtractedLead {
  id                String    @id @default(cuid())
  organizationId    String
  jobId             String
  placeId           String?
  name              String?
  segment           String?
  address           String?
  phone             String?
  whatsapp          String?
  email             String?
  website           String?
  instagram         String?
  facebook          String?
  linkedin          String?
  rating            Float?
  /// Set once the user imports this lead into the CRM (idempotent).
  importedCompanyId String?
  importedAt        DateTime?
  createdAt         DateTime  @default(now())

  job ExtractionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([organizationId, jobId])
  @@map("extracted_leads")
}

// ---------------------------------------------------------------------------
// WhatsApp inbox (chat)
// ---------------------------------------------------------------------------
// Conversations and messages mirrored from the tenant's Evolution instance via
// the inbound webhook. The durable record of the chat lives here.

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  UNKNOWN
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

/// Lifecycle of a message's media bytes in our own storage (Vercel Blob).
enum MediaStatus {
  PENDING
  READY
  FAILED
}

/// A WhatsApp chat with one remote party (a contact's number), tied to the
/// Evolution connection it flows through.
model Conversation {
  id                 String    @id @default(cuid())
  organizationId     String
  connectionId       String
  /// WhatsApp JID, e.g. "5511999999999@s.whatsapp.net".
  remoteJid          String
  name               String?
  /// User-set label that overrides the WhatsApp push name in the list. Never
  /// touched by inbound ingestion, so a rename sticks.
  customName         String?
  /// Optional link to a CRM contact (identified/created from the number).
  contactId          String?
  /// WhatsApp profile-picture URL + when we last refreshed it (cached ~weekly).
  avatarUrl          String?
  avatarCheckedAt    DateTime?
  /// Team member this conversation is assigned to (a User id), if any.
  assignedToId       String?
  /// Inbox organization: pin to top and optional folder.
  pinned             Boolean   @default(false)
  folderId           String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadCount        Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  messages Message[]
  folder   ConversationFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([connectionId, remoteJid])
  @@index([organizationId, lastMessageAt])
  @@map("conversations")
}

/// A folder to organize the WhatsApp inbox (org-scoped). Inbox-specific —
/// independent of the CRM's ContactFolder.
model ConversationFolder {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversations Conversation[]

  @@index([organizationId, order])
  @@map("conversation_folders")
}

/// A single message within a conversation (inbound or outbound).
model Message {
  id                String           @id @default(cuid())
  organizationId    String
  conversationId    String
  direction         MessageDirection
  type              MessageType      @default(TEXT)
  body              String?
  mediaUrl          String?
  mediaMime         String?
  /// PENDING = bytes still being fetched/stored; READY = playable; FAILED = give up.
  mediaStatus       MediaStatus?
  /// Original filename (documents) and known metadata captured from the webhook.
  mediaName         String?
  mediaSize         Int?
  /// Audio/video length in seconds (lets the player render before bytes load).
  mediaDurationSec  Int?
  mediaWidth        Int?
  mediaHeight       Int?
  /// Provider message id (Baileys key id) — idempotency + status mapping.
  providerMessageId String?
  status            MessageStatus?
  fromMe            Boolean          @default(false)
  timestamp         DateTime
  createdAt         DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@index([providerMessageId])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Finance (Financeiro) — DRE, cash flow, entries (receitas/despesas)
// ---------------------------------------------------------------------------

/// Whether an entry is money in (receita) or money out (despesa).
enum FinanceType {
  INCOME
  EXPENSE
}

/// PENDING = a receber / a pagar; SETTLED = recebido / pago (realizado).
enum FinanceStatus {
  PENDING
  SETTLED
}

/// Payment method for an entry (optional).
enum FinanceMethod {
  PIX
  BOLETO
  CARD
  CASH
  TRANSFER
  OTHER
}

/// A DRE/report category, scoped to the org and to a type (receita/despesa).
model FinanceCategory {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  type           FinanceType
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  entries FinanceEntry[]

  @@unique([organizationId, type, name])
  @@index([organizationId, type])
  @@map("finance_categories")
}

/// A financial entry (lançamento): a single receita or despesa. The ledger that
/// feeds Receitas, Despesas, Fluxo de Caixa and DRE. CRM links are stored as ids
/// (no PII duplicated); names are resolved at read time.
model FinanceEntry {
  id                 String         @id @default(cuid())
  organizationId     String
  type               FinanceType
  description        String
  amount             Decimal        @db.Decimal(12, 2)
  status             FinanceStatus  @default(PENDING)
  /// Competência/vencimento (accrual basis — drives DRE).
  dueDate            DateTime
  /// When it was actually paid/received (cash basis — drives Fluxo de Caixa).
  settledAt          DateTime?
  method             FinanceMethod?
  notes              String?
  categoryId         String?
  /// Optional CRM links (ids only).
  contactId          String?
  companyId          String?
  opportunityId      String?
  /// Installments: entries of the same sale share a group id (NNNN.../uuid),
  /// with their position (installmentNo) out of installmentTotal.
  installmentGroupId String?
  installmentNo      Int?
  installmentTotal   Int?
  createdById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  category FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([organizationId, dueDate])
  @@index([organizationId, type, status])
  @@index([organizationId, settledAt])
  @@index([organizationId, opportunityId])
  @@index([organizationId, contactId])
  @@map("finance_entries")
}

// ---------------------------------------------------------------------------
// Tasks / Activities — the follow-up layer that links CRM, inbox and finance.
// ---------------------------------------------------------------------------

enum TaskType {
  CALL
  MEETING
  EMAIL
  WHATSAPP
  FOLLOWUP
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// A task / next action (org-scoped). Optionally tied to a contact, company or
/// opportunity (ids only, like Conversation/FinanceEntry — names resolved on
/// read). `doneAt` marks completion.
model Task {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  description    String?
  type           TaskType     @default(OTHER)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  doneAt         DateTime?
  assignedToId   String? // User responsible
  createdById    String?
  contactId      String?
  companyId      String?
  opportunityId  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, assignedToId, doneAt])
  @@index([organizationId, dueDate])
  @@index([organizationId, opportunityId])
  @@index([organizationId, contactId])
  @@map("tasks")
}

/// A persistent notification for the user. Used for assigned tasks, mentions,
/// and daily digests of overdue/stale items.
model Notification {
  id             String @id @default(cuid())
  organizationId String
  userId         String

  /// Granular kind, drives the icon + localized label in the bell. One of the
  /// NotificationKind values (see src/lib/notifications/kinds.ts).
  type String

  /// i18n interpolation values for the localized message (e.g. { count } for a
  /// digest, or { actor, title } for an assignment). Rendered client-side.
  data Json?

  /// Where clicking the notification navigates (e.g. "/app/tasks/123").
  link String?

  /// Set when the user clears notifications or opens this one.
  readAt DateTime?

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Internal Team Chat
// ---------------------------------------------------------------------------

enum TeamChatAttachmentType {
  TASK
  OPP
  CONTACT
  COMPANY
  LEAD
}

model TeamChat {
  id                 String    @id @default(cuid())
  organizationId     String
  /// Canonical key for a 1:1 chat ("<orgId>:<sortedUserIdA>:<sortedUserIdB>"),
  /// unique so a direct chat can be upserted without racing duplicates.
  dmKey              String?   @unique
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  participants TeamChatParticipant[]
  messages     TeamChatMessage[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, lastMessageAt])
}

model TeamChatParticipant {
  id             String   @id @default(cuid())
  organizationId String
  chatId         String
  userId         String
  unreadCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  chat         TeamChat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([organizationId, userId])
}

model TeamChatMessage {
  id             String @id @default(cuid())
  organizationId String
  chatId         String
  senderId       String
  body           String

  attachmentType  TeamChatAttachmentType?
  attachmentId    String?
  /// Snapshot of the attached entity's label + link, resolved at send time so
  /// the bubble renders without N+1 lookups and survives the entity changing.
  attachmentLabel String?
  attachmentHref  String?

  createdAt DateTime @default(now())

  chat         TeamChat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model TeamChatFolder {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships  Membership[]

  @@index([organizationId, order])
  @@map("team_chat_folders")
}

// ---------------------------------------------------------------------------
// Team feed (ephemeral 24h posts by managers, with mentions + reactions)
// ---------------------------------------------------------------------------

model FeedPost {
  id             String   @id @default(cuid())
  organizationId String
  authorId       String
  body           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments  FeedPostAttachment[]
  mentions     FeedMention[]
  reactions    FeedReaction[]

  @@index([organizationId, createdAt])
  @@map("feed_posts")
}

model FeedPostAttachment {
  id             String                 @id @default(cuid())
  organizationId String
  postId         String
  type           TeamChatAttachmentType
  entityId       String
  /// Snapshot of the entity's label + link, resolved at post time.
  label          String
  href           String

  post         FeedPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([postId])
  @@map("feed_post_attachments")
}

model FeedMention {
  id             String @id @default(cuid())
  organizationId String
  postId         String
  userId         String

  post         FeedPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([organizationId])
  @@map("feed_mentions")
}

model FeedReaction {
  id             String   @id @default(cuid())
  organizationId String
  postId         String
  userId         String
  emoji          String
  createdAt      DateTime @default(now())

  post         FeedPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([organizationId])
  @@index([postId])
  @@map("feed_reactions")
}

// ---------------------------------------------------------------------------
// Personal hub (Meus Itens) — pins/favourites
// ---------------------------------------------------------------------------

/// Entity kinds a user can pin. Values mirror resolveAttachment() so the same
/// resolver builds the label + link.
enum PinnedEntity {
  TASK
  OPP
  CONTACT
  COMPANY
}

/// A user's pinned/favourited item, shown on their personal hub. One per
/// (user, entity); org-scoped.
model PinnedItem {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  entityType     PinnedEntity
  entityId       String
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([organizationId, userId])
  @@map("pinned_items")
}
