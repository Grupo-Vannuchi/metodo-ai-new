# ─────────────────────────────────────────────────────────────────────────
#  MétodoAI — Environment variables
#  Copy to `.env` and fill in. Validated at boot by src/lib/env.ts (zod).
# ─────────────────────────────────────────────────────────────────────────

# --- Database (PostgreSQL) ---------------------------------------------------
# Local dev: the bundled Docker Postgres (see docker-compose.yml) on DB_PORT.
# Production (Neon/Supabase): use the POOLED connection (pgBouncer) for
# DATABASE_URL and the DIRECT connection for DIRECT_URL (used by migrations).
DB_PORT=5433
DATABASE_URL="postgresql://metodoai:metodoai@localhost:5433/metodoai?schema=public"
DIRECT_URL="postgresql://metodoai:metodoai@localhost:5433/metodoai?schema=public"

# --- Auth --------------------------------------------------------------------
# 32+ chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-32-char-minimum-random-secret"

# --- Public ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Seed (first admin/owner of the demo organization) -----------------------
SEED_OWNER_EMAIL="owner@metodoai.local"
SEED_OWNER_PASSWORD="changeme123"
SEED_ORG_NAME="MétodoAI Demo"

# ─────────────────────────────────────────────────────────────────────────
#  The keys below are NOT required yet — they are introduced in later phases.
#  Listed here so you know what to provision. (Not validated by env.ts until
#  the phase that uses them lands.)
# ─────────────────────────────────────────────────────────────────────────

# --- P4: Background jobs / cache (Upstash) -----------------------------------
# QSTASH_TOKEN=""
# QSTASH_CURRENT_SIGNING_KEY=""
# QSTASH_NEXT_SIGNING_KEY=""
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- P4: Integration credential encryption (AES-256-GCM, 64 hex chars) -------
# INTEGRATION_ENC_KEY=""

# --- P5/P6: Integrations -----------------------------------------------------
# GOOGLE_MAPS_API_KEY=""
# GOOGLE_CSE_API_KEY=""
# GOOGLE_CSE_CX=""
# RESEND_API_KEY=""
